# DashScope LLM (Required)
DASHSCOPE_API_KEY=
LLM_MODEL=
EMBEDDING_MODEL=text-embedding-v3

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# MySQL
MYSQL_URL=jdbc:mysql://localhost:3306/interview_agent?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai
MYSQL_USERNAME=root
MYSQL_PASSWORD=interview

# JWT
JWT_SECRET=interview-agent-default-secret

# GitHub (Optional)
GITHUB_TOKEN=

# Auth
AUTH_ENABLED=true
